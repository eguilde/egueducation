PORT=8080
FRONTEND_ORIGIN=http://localhost:4200
APP_ENV=development

# Local development should use the dedicated app user and the external database endpoint.
# Keep real credentials only in backend/.env, which is intentionally gitignored.
DATABASE_HOST=db.eguilde.cloud
DATABASE_PORT=5432
DATABASE_NAME=scoalabalotesti
DATABASE_USERNAME=egueducation_scoalabalotesti_app
DATABASE_PASSWORD=
DATABASE_SSLMODE=require
DATABASE_URL=postgres://egueducation_scoalabalotesti_app:<url-encoded-password>@db.eguilde.cloud:5432/scoalabalotesti?sslmode=require

OIDC_ISSUER=http://localhost:8080/api/oidc
OIDC_CLIENT_ID=egueducation-spa
OIDC_DESKTOP_CLIENT_ID=egueducation-desktop

SMSAPI_TOKEN=
SMS_SENDER_NAME=EguEducation

ENABLE_SMS_OTP=true
ENABLE_PASSKEYS=true
ENABLE_EUDI_WALLET=true
ENABLE_GDPR_FEATURES=true

ARCHIVE_STORAGE_ENDPOINT=http://localhost:9000
ARCHIVE_STORAGE_REGION=us-east-1
ARCHIVE_STORAGE_BUCKET=archive-documents
ARCHIVE_STORAGE_ACCESS_KEY=minioadmin
ARCHIVE_STORAGE_SECRET_KEY=minioadmin123
ARCHIVE_STORAGE_USE_PATH_STYLE=true
# Textract staging uses the standard AWS env vars (AWS_REGION, AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY).
ARCHIVE_TEXTRACT_BUCKET=archive-textract-staging
ARCHIVE_TEXTRACT_REGION=us-east-1
# AWS credentials for Textract can come from the standard AWS_* env vars or shared config.
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ARCHIVE_WORKER_ENABLED=true
ARCHIVE_WORKER_POLL_INTERVAL_SECONDS=5
